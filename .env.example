PORT=3000

# REQUIRED — Postgres connection string (e.g. a free database at neon.tech).
DATABASE_URL=

# REQUIRED to enable the responses dashboard at /admin (disabled if unset).
# Generate a strong value: openssl rand -hex 32
ADMIN_KEY=

# REQUIRED for Nqoot card gifts — the couple's Stripe SECRET key (sk_live_… or
# sk_test_…). Nqoot uses Stripe Checkout; the gift is verified when Stripe
# redirects back, so no webhook secret is needed.
STRIPE_SECRET_KEY=

# OPTIONAL — public https URL of the deployed site, used to build the Stripe
# return links. If unset it's derived from the incoming request, which is fine
# for most hosts. Set it if your host sits behind a proxy that rewrites host.
# PUBLIC_URL=https://your-domain.com
